# Copy to apps/web/.env.local for local development. Never commit real values.

# AI provider (development phase: Google Gemini — https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Supabase (project settings → API)
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# GitHub OAuth app (M1) — identity only, no repo scopes
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
