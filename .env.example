# Copy to apps/web/.env.local for local development. Never commit real values.

# Supabase (project settings → API). Auth (GitHub sign-in) is configured in
# the Supabase dashboard: Authentication → Providers → GitHub, using a GitHub
# OAuth app whose callback URL is https://<project-ref>.supabase.co/auth/v1/callback
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The app's public origin (no trailing slash), used to build ABSOLUTE permalinks
# baked into inserted cross-references so documents render their elements
# standalone anywhere (published site, downloaded copy). Set to the production
# origin so an insert made in local dev still points at production, not
# localhost. Falls back to window.location.origin when unset.
# e.g. https://alembic.orz.how
NEXT_PUBLIC_APP_URL=

# Server-only Supabase key (worker tier / admin exports; not needed for M1)
SUPABASE_SECRET_KEY=

# ── AI provider ────────────────────────────────────────────────────────────
# Provider-swappable (CLAUDE.md rule 6). The app prefers an OpenAI-compatible
# GATEWAY when AI_GATEWAY_URL + AI_GATEWAY_API_KEY are set; otherwise it falls
# back to Gemini-direct. Set ONE of the two.
#
# (a) Gemini direct — development/testing default (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
#
# (b) Gateway — Portkey (recommended control plane: governance, per-user/org
#     budgets, FERPA/IRB data controls) or OpenRouter. Both are OpenAI-compatible.
#     PORTKEY recipe (free tier is fine for light testing):
#       1. Create a Portkey account; copy your Portkey API key.
#       2. Add a provider integration (Model Catalog) for Google/Gemini and note
#          its slug, e.g. "alembic-gemini".
#       3. Set (the Portkey key goes in Authorization: Bearer; model ids use the
#          catalog slug "@<provider-slug>/<model>" — no virtual-key header needed):
#         AI_GATEWAY_URL=https://api.portkey.ai/v1
#         AI_GATEWAY_API_KEY=<portkey-api-key>
#         AI_MODEL_DEFAULT=@alembic-gemini/gemini-2.5-flash
#         AI_MODEL_STRONG=@alembic-gemini/gemini-2.5-pro
#       (Older Portkey accounts route via a virtual key instead — then set
#        AI_GATEWAY_HEADERS={"x-portkey-virtual-key":"<vk>"} and use bare model ids.)
#     OpenRouter recipe:
#         AI_GATEWAY_URL=https://openrouter.ai/api/v1
#         AI_GATEWAY_API_KEY=<openrouter-key>
#         AI_GATEWAY_HEADERS={"HTTP-Referer":"https://alembic.orz.how","X-Title":"Alembic"}
AI_GATEWAY_URL=
AI_GATEWAY_API_KEY=
# Optional JSON object of extra request headers (gateway routing/attribution):
AI_GATEWAY_HEADERS=
#
# Task→model routing (model ids must be valid for whatever provider you wire).
# AI_MODEL_DEFAULT is the fallback; AI_MODEL_FAST/STRONG override the cheap-vs-
# strong split (set all three the same to collapse to one model for testing).
AI_MODEL_DEFAULT=
AI_MODEL_FAST=
AI_MODEL_STRONG=
#
# Optional per-user token budget (M16). Dormant unless AI_TOKEN_BUDGET is set
# (needs migration 0007). Window defaults to 30 days.
AI_TOKEN_BUDGET=
AI_BUDGET_WINDOW_SECONDS=

# GitHub App for publishing (M5). See docs/GitHubAppSetup.md.
GITHUB_APP_ID=
GITHUB_APP_SLUG=
# PEM private key with literal newlines escaped as \n, on one line:
GITHUB_APP_PRIVATE_KEY=
GITHUB_TEMPLATE_OWNER=
GITHUB_PUBLIC_TEMPLATE=alembic-public-template
GITHUB_PRIVATE_TEMPLATE=alembic-private-template

# --- Worker tier (self-contained file generation) ---
# The web app calls the worker to generate live-editable .md.html/.slides.html/
# .paged.html (the upstream generators are Node-only and read package assets,
# so they can't run in Vercel serverless). Unset → in-process fallback (rendered
# docs, no in-file editor), so exports keep working without a worker.
# Local: `pnpm dev:worker` then WORKER_URL=http://localhost:8787
WORKER_URL=
# Optional shared secret; if set, the worker requires Authorization: Bearer <token>.
WORKER_TOKEN=
