{
  "name": "@alembic/worker",
  "version": "0.1.0",
  "private": true,
  "description": "Container worker tier: site builds and Pages publication behind a job queue. v0.1 runs build jobs in-process during local dev.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@alembic/package-contract": "workspace:*",
    "@alembic/renderer": "workspace:*",
    "@alembic/generators": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.22.4"
  }
}
